+#define IN_TARGET_CODE 1
+
+#include "config.h"
+#include "system.h"
+#include "coretypes.h"
+#include "tm.h"
+#include "rtl.h"
+#include "backend.h"
+#include "regs.h"
+#include "target.h"
+#include "memmodel.h"
+#include "emit-rtl.h"
+#include "df.h"
+#include "predict.h"
+#include "tree-pass.h"
+#include "cfgrtl.h"
+
+/*
+This optimization is mainly to explain the low address of ADDI to the memory offset of ld/st,
+reducing the low address calculation instructions.
+1) if non-gprelax:
+lui + addi + add + ld/st ---> lui + add + ld/st (iff addend == 0)
+lui + addi + addi + add + ld/st ---> lui + add + ld/st (iff addend > 0)
+2) if gprelax:
+addi + add + ld/st ---> add + ld/st
+*/
+
+namespace {
+
+const pass_data pass_data_fold_gp =
+{
+  RTL_PASS, /* type */
+  "fold_gp", /* name */
+  OPTGROUP_NONE, /* optinfo_flags */
+  TV_NONE, /* tv_id */
+  0, /* properties_required */
+  0, /* properties_provided */
+  0, /* properties_destroyed */
+  0, /* todo_flags_start */
+  0, /* todo_flags_finish */
+};
+
+class pass_fold_gp : public rtl_opt_pass
+{
+public:
+  pass_fold_gp (gcc::context *ctxt)
+    : rtl_opt_pass (pass_data_fold_gp, ctxt)
+  {}
+
+  /* opt_pass methods: */
+  virtual bool gate (function *)
+    {
+      return optimize > 0;
+    }
+  virtual unsigned int execute (function *);
+
+private:
+
+  void analyze_and_transform (rtx_insn *hi, rtx_insn *lo, rtx_insn *add, rtx_insn *mem);
+  bool detectFoldable(rtx_insn *high_insn, rtx_insn *&lo_insn);
+  rtx getMemAddr (rtx_insn *mem);
+  void sym_add_mem_off (rtx_insn *&hi, rtx_insn *&lo, rtx_insn *mem);
+  bool foldGPIntoMemoryOps(rtx_insn *lo, rtx_insn *&add, rtx_insn *&mem);
+}; // class pass_fold_gp
+
+/*
+  Iff the insn has only one used insn, and use_insn can't be used in JUMP or CALL,
+  and except the DEBUG Insn.
+*/
+static bool hasOneUse (rtx_insn *insn, rtx dest, rtx_insn *&use_insn)
+{
+  if (!REG_P(dest))
+    return false;
+
+  df_ref use;
+  int use_count = 0;
+  unsigned int regno = REGNO (dest);
+
+  for (use = DF_REG_USE_CHAIN (regno); use; use = DF_REF_NEXT_REG (use))
+  {
+    if (!DF_REF_INSN_INFO(use))
+      continue;
+
+    if (CALL_P (DF_REF_INSN (use)) || JUMP_P (DF_REF_INSN (use)))
+      return false;
+
+    if (DEBUG_INSN_P (DF_REF_INSN (use)))
+      continue;
+
+    use_count++;
+    use_insn = DF_REF_INSN (use);
+  }
+
+  if (use_count == 1 && use_insn)
+    return true;
+
+  return false;
+}
+
+/* Symbol Bind is not local can be optimize */
+static bool symbol_binds_local_p (const_rtx x)
+{
+  if (SYMBOL_REF_P (x))
+    return (SYMBOL_REF_DECL (x)
+	    ? targetm.binds_local_p (SYMBOL_REF_DECL (x))
+	    : SYMBOL_REF_LOCAL_P (x));
+  else
+    return false;
+}
+
+/*
+Detect the patterns:
+(insn 6 3 7 2 (set (reg/f:DI 137)
+                   (high:DI (symbol_ref:DI ("bin_infos") [flags 0xc0]  <var_decl 0x7f6f6ccc2c60
+(insn 7 6 9 2 (set (reg/f:DI 138)
+                   (lo_sum:DI (reg/f:DI 137)
+                              (symbol_ref:DI ("bin_infos") [flags 0xc0]  <var_decl 0x7f6f6ccc2c60
+
+The pattern is only accepted if:
+   1) The first instruction has only one use, which is the LO_SUM
+   2) The symbol need is the Global Address
+*/
+bool pass_fold_gp::detectFoldable(rtx_insn *hi_insn, rtx_insn *&lo_insn) {
+  rtx hi_set = single_set (hi_insn);
+  if (hi_set == NULL_RTX)
+    return false;
+
+  if (GET_CODE (SET_SRC (hi_set)) != HIGH)
+    return false;
+
+  if (GET_CODE (XEXP (SET_SRC (hi_set), 0)) != SYMBOL_REF ||
+      symbol_binds_local_p (XEXP (SET_SRC (hi_set), 0)))
+    return false;
+  
+  if (!hasOneUse(hi_insn, SET_DEST (hi_set), lo_insn))
+    return false;
+
+  rtx lo_set = single_set (lo_insn);
+  if (lo_set == NULL_RTX)
+    return false;
+
+  if (GET_CODE (SET_SRC (lo_set)) != LO_SUM)
+    return false;
+
+  if (GET_CODE (XEXP (SET_SRC (lo_set), 1)) != SYMBOL_REF ||
+      symbol_binds_local_p (XEXP (SET_SRC (lo_set), 1)))
+    return false;
+
+  return true;
+}
+
+// Mem Pattern as:
+// 1. (set (mem:SI (reg/f:DI 139)
+// 2. (set (reg/i:DI 10 a0) (mem:DI (reg/f:DI 140)
+// 3. (set (reg/i:DI 10 a0) (zero_extend:DI (mem:QI (reg/f:DI 139)
+// 4. (set (reg/i:DI 10 a0) (sign_extend:DI (mem:SI (reg/f:DI 139)
+rtx pass_fold_gp::getMemAddr (rtx_insn *mem) {
+  if (!mem)
+    return NULL_RTX;
+
+  rtx mem_dst = SET_DEST (PATTERN (mem));
+  rtx mem_src = SET_SRC (PATTERN (mem));
+
+  if (MEM_P (mem_src))
+    return XEXP (mem_src, 0);
+  else if (MEM_P (mem_dst))
+    return XEXP (mem_dst, 0);
+  else if ((GET_CODE (mem_src) == ZERO_EXTEND ||
+      GET_CODE (mem_src) == SIGN_EXTEND) &&
+      MEM_P (XEXP (mem_src, 0)))
+    return XEXP (XEXP (mem_src, 0), 0);
+}
+
+static void update_lui_and_lo (rtx_insn *&hi, rtx_insn *&lo,
+                               rtx sym, HOST_WIDE_INT offset) {
+  machine_mode mode = GET_MODE (sym);
+  rtx off = gen_rtx_PLUS(mode, sym, GEN_INT(offset));
+  rtx sym_and_off =  gen_rtx_CONST(mode, off);
+  // update hi symbol
+  XEXP (SET_SRC (PATTERN (hi)), 0) = sym_and_off;
+  // update lo symbol
+  XEXP (SET_SRC (PATTERN (lo)), 1) = sym_and_off;
+}
+
+/*
+Example as:
+extern long long g[10];
+long long __attribute__((noinline)) foo(int i) {
+  return g[i + 3];
+}
+
+(set (reg/f:DI 138)
+     (high:DI (symbol_ref:DI ("g2") [flags 0xc0])))
+(set (reg/f:DI 139)
+     (lo_sum:DI (reg/f:DI 138)
+                (symbol_ref:DI ("g2") [flags 0xc0])))
+(set (reg:DI 141)
+     (sign_extend:DI (plus:SI (subreg:SI (reg:DI 146) 0)
+                              (const_int 3 [0x3]))))
+(set (reg/f:DI 144)
+     (plus:DI (ashift:DI (reg:DI 141) (const_int 3 [0x3]))
+                         (reg/f:DI 139)))
+(set (reg/i:DI 10 a0)
+     (mem:DI (reg/f:DI 144) [2 g2[_1]+0 S8 A64]))
+
+------ Transform -------
+
+(set (reg/f:DI 138)
+     (high:DI (const:DI (plus:DI (symbol_ref:DI ("g2"))
+                                 (const_int 24 [0x18])))))
+(set (reg/f:DI 139)
+     (lo_sum:DI (reg/f:DI 138)
+     (const:DI (plus:DI (symbol_ref:DI ("g2"))
+                        (const_int 24 [0x18])))
+(set (reg/f:DI 144)
+     (plus:DI (ashift:DI (reg:DI 146) (const_int 3 [0x3]))
+                         (reg/f:DI 139)))
+(set (reg/i:DI 10 a0) (mem:DI (reg/f:DI 144) [2 g2[_1]+0 S8 A64]))
+*/
+static void remove_addi_update_lui_and_lo (rtx_insn *&hi_insn,
+                                           rtx_insn *&lo_insn, rtx_insn *&add_insn) {
+  rtx add_src = SET_SRC (PATTERN (add_insn));
+  rtx reg = XEXP (add_src, 0) == SET_DEST (PATTERN (lo_insn)) ?
+            XEXP (add_src, 1) : XEXP (add_src, 0);
+  HOST_WIDE_INT shift_num = 0;
+  rtx_insn *def_insn = NULL;
+  df_ref def;
+  bool add_ashift_sep = false;
+  if (GET_CODE (reg) == REG)
+  {
+    def = DF_REG_DEF_CHAIN (REGNO (reg));
+    def_insn = DF_REF_INSN (def);
+    // When Target not support zba && split the shift and plus insn,
+    // we need update the ashift src'0. Otherwise only deal with the plus
+    // (set (reg:DI 143)
+    //      (ashift:DI (reg:DI 141)
+    //                 (const_int 1 [0x1])))
+    // (set (reg/f:DI 144)
+    //      (plus:DI (reg/f:DI 139)
+    //               (reg:DI 143)))
+    if (def_insn && GET_CODE (PATTERN (def_insn)) == SET &&
+        GET_CODE (SET_SRC (PATTERN (def_insn))) == ASHIFT)
+    {
+        add_src = SET_SRC (PATTERN (def_insn));
+        shift_num = INTVAL (XEXP (SET_SRC (PATTERN (def_insn)), 1));
+        def = DF_REG_DEF_CHAIN (REGNO (XEXP (SET_SRC (PATTERN (def_insn)), 0)));
+        add_ashift_sep = true;
+    }
+  }
+  else if (GET_CODE (reg) == ASHIFT)
+  {
+    shift_num = INTVAL (XEXP (reg, 1));
+    def = DF_REG_DEF_CHAIN (REGNO (XEXP (reg, 0)));
+  }
+
+  def_insn = DF_REF_INSN (def);
+  rtx def_pat = PATTERN (def_insn);
+  rtx def_src = SET_SRC (def_pat);
+  rtx def_dst = SET_DEST (def_pat);
+
+  rtx_insn *def_insn_use = NULL;
+  if (!hasOneUse(def_insn, def_dst, def_insn_use))
+    return;
+
+  machine_mode mode = GET_MODE(def_dst);
+  if (GET_CODE (def_src) == SIGN_EXTEND && GET_CODE (XEXP (def_src, 0)) == PLUS &&
+      GET_CODE (XEXP (XEXP (def_src, 0), 1)) == CONST_INT) {
+      HOST_WIDE_INT off = INTVAL (XEXP (XEXP (def_src, 0), 1)) << shift_num;
+    rtx update_add_dst = XEXP (XEXP (XEXP (def_src, 0), 0), 0);
+    // FIXME: pr68619-2.c will failed
+    if (!SUBREG_P (XEXP (XEXP (def_src, 0), 0)))
+      return;
+
+    if (SMALL_OPERAND (off)) {
+      update_lui_and_lo (hi_insn, lo_insn, XEXP (SET_SRC (PATTERN (hi_insn)), 0), off);
+
+      if (add_ashift_sep) {
+        XEXP (add_src, 0) = update_add_dst;
+      } else {
+      if (GET_CODE (reg) == ASHIFT)
+        XEXP (reg, 0) = update_add_dst;
+      else if (reg == XEXP (add_src, 0))
+        XEXP (add_src, 0) = update_add_dst;
+      else if (reg == XEXP (add_src, 1))
+        XEXP (add_src, 1) = update_add_dst;
+      }
+      delete_insn(def_insn);
+      df_insn_rescan(add_insn);
+    }
+  }
+}
+
+/*
+mainly deal with access the struct member varival which not the first.
+Update the sym with mem's addr offset.
+example as:
+struct bin_info_s {
+  int reg_size;
+  int slab_size;
+};
+typedef struct bin_info_s bin_info_t;
+int  __attribute__((noinline)) test_gp(int i) {
+  bin_info_t *bin_info = &bin_infos[i];
+  return bin_info->slab_size;
+}
+
+Pattern Transform:
+(set (reg/f:DI 137)
+     (high:DI (symbol_ref:DI ("bin_infos") [flags 0xc0])))
+(set (reg/f:DI 138)
+     (lo_sum:DI (reg/f:DI 137)
+                (symbol_ref:DI ("bin_infos") [flags 0xc0])))
+(set (reg/f:DI 139)
+     (plus:DI (reg/f:DI 138) (reg:DI 140)))
+(set (reg/i:DI 10 a0)
+     (zero_extend:DI (mem:QI (plus:DI (reg/f:DI 139) (const_int 4 [0x4])))))
+
+------ Transform --------
+
+(set (reg/f:DI 137)
+     (high:DI (const:DI (plus:DI (symbol_ref:DI ("bin_infos"))
+                                 (const_int 4 [0x4])))))
+(set (reg/f:DI 138)
+     (lo_sum:DI (reg/f:DI 137)
+                (const:DI (plus:DI (symbol_ref:DI ("bin_infos"))
+                                   (const_int 4 [0x4])))))
+(set (reg/f:DI 139)
+     (plus:DI (reg/f:DI 138) (reg:DI 140)))
+(set (reg/i:DI 10 a0)
+    (zero_extend:DI (mem:QI (plus:DI (reg/f:DI 139) (const_int 4 [0x4])))))
+*/                        
+void pass_fold_gp::sym_add_mem_off (rtx_insn *&hi, rtx_insn *&lo,
+                                    rtx_insn *mem) {
+  rtx mem_plus = getMemAddr (mem);
+
+  if (mem_plus != NULL_RTX && GET_CODE (mem_plus) == PLUS &&
+      GET_CODE (XEXP (mem_plus, 1)) == CONST_INT) {
+    HOST_WIDE_INT off = INTVAL (XEXP (mem_plus, 1));
+    update_lui_and_lo (hi, lo, XEXP (SET_SRC (PATTERN (hi)), 0), off);
+  }
+}
+
+/*
+Non-constant addressing of global array subscripts, which can be
+increase the optimization scenarios of gp-relax
+
+C example as:
+extern char arr[42];
+char foo(int i) {
+  return arr[i];
+}
+
+Insn Pattern as:
+(insn 6 3 7 2 (set (reg/f:DI 137)
+              (high:DI (symbol_ref:DI ("g2") (nil))
+(insn 7 6 8 2 (set (reg/f:DI 138)
+              (lo_sum:DI (reg/f:DI 137) (symbol_ref:DI ("g2")
+(insn 8 7 9 2 (set (reg/f:DI 139)
+              (plus:DI (reg/f:DI 138) (reg:DI 143)))
+(insn 16 11 17 2 (set (reg/i:DI 10 a0)
+                 (zero_extend:DI (mem:QI (reg/f:DI 139)
+*/
+bool
+pass_fold_gp::foldGPIntoMemoryOps(rtx_insn *lo, rtx_insn *&add, rtx_insn *&mem) {
+  rtx lo_set = single_set (lo);
+  if (lo_set == NULL_RTX)
+    return false;
+
+  if (!hasOneUse(lo, SET_DEST (lo_set), add))
+    return false;
+
+  // Support Plus Pattern:
+  // 1. (plus:DI (reg/f:DI 137) (reg:DI 140)))
+  // 2. (plus:DI (ashift:DI (reg:DI 141) (const_int x [0xx])) (x is 1/2/3)
+  //             (reg/f:DI 137)))
+  if (GET_CODE (PATTERN (add)) != SET ||
+      GET_CODE (SET_SRC (PATTERN (add))) != PLUS ||
+     (GET_CODE (XEXP (SET_SRC (PATTERN (add)), 0)) != REG &&
+      GET_CODE (XEXP (SET_SRC (PATTERN (add)), 0)) != ASHIFT))
+    return false;
+
+  if (!hasOneUse (add,  SET_DEST (PATTERN (add)), mem))
+    return false;
+
+  rtx mem_pat = PATTERN (mem);
+  rtx mem_dst = SET_DEST (mem_pat);
+  rtx mem_src = SET_SRC (mem_pat);
+
+  // Support Mem Pattern as:
+  // 1. (set (mem:SI (reg/f:DI 139)
+  // 2. (set (reg/i:DI 10 a0) (mem:DI (reg/f:DI 140)
+  // 3. (set (reg/i:DI 10 a0) (zero_extend:DI (mem:QI (reg/f:DI 139)
+  // 4. (set (reg/i:DI 10 a0) (sign_extend:DI (mem:SI (reg/f:DI 139)
+  if (!MEM_P (mem_dst) && !MEM_P (mem_src) && !((GET_CODE (mem_src) == ZERO_EXTEND ||
+      GET_CODE (mem_src) == SIGN_EXTEND) && MEM_P (XEXP (mem_src, 0))))
+    return false;
+
+  return true;
+}
+
+void pass_fold_gp::analyze_and_transform (rtx_insn *hi, rtx_insn *lo, rtx_insn *add, rtx_insn *mem) {
+  if (!detectFoldable(hi, lo))
+    return;
+
+  if (foldGPIntoMemoryOps(lo, add, mem)) {
+    remove_addi_update_lui_and_lo (hi, lo, add);
+    sym_add_mem_off (hi, lo, mem);
+    targetm.gprel_sym_emit(hi, lo, add, mem);
+  }
+}
+
+unsigned int
+pass_fold_gp::execute (function *fn)
+{
+  basic_block bb;
+  rtx_insn *insn;
+  FOR_ALL_BB_FN (bb, fn)
+  {
+    FOR_BB_INSNS (bb, insn)
+      analyze_and_transform(insn, NULL, NULL, NULL);
+  }
+
+  return 0;
+}
+
+} // anon namespace
+
+rtl_opt_pass *
+make_pass_fold_gp (gcc::context *ctxt)
+{
+  return new pass_fold_gp (ctxt);
+}
