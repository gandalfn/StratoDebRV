+		break;
+	      INSERT_OPERAND (SPACEMIT_IME_WI, *ip, regno);
+	      continue;
+	    case 'e':
+	      if (!arg_lookup (&asarg, riscv_spacemit_ime_wi_names_numeric_2, ARRAY_SIZE (riscv_spacemit_ime_wi_names_numeric_2), &regno))
+		break;
+	      if ((regno & 0x3) == 0 || (regno & 0x3) == 1)
+		{
+		    as_bad (_("bad width field, "
+			    "width not support i2/i16"));
+		    break;
+		}
+	      INSERT_OPERAND (SPACEMIT_IME_WI, *ip, regno);
+	      continue;
+	    case 'J':
+	      if (!reg_lookup (&asarg, RCLASS_SPACEMIT_IME_WI, &regno))
+		    break;
+	      if ((regno & 0x3) != 2 && (regno & 0x3) != 3) {
+		    as_bad (_("bad width field, "
+			    "width only support i4 & i8"));
+		    break;
+	      }
+	      INSERT_OPERAND (SPACEMIT_IME_WI, *ip, regno);
+	      continue;
+	    case 'w':
+	      if (!reg_lookup (&asarg, RCLASS_SPACEMIT_IME_WI, &regno))
+		    break;
+	      if ((regno & 0x3) != 3) {
+		    as_bad (_("bad width field, "
+			    "width only support i8"));
+		    break;
+	      }
+	      INSERT_OPERAND (SPACEMIT_IME_WI, *ip, regno);
+	      continue;
+	    case 'H':
+	      my_getExpression (imm_expr, asarg);
+	      check_absolute_expr (ip, imm_expr, FALSE);
+	      if (imm_expr->X_add_number < 0 || imm_expr->X_add_number >= 8)
+		    as_bad (_("bad value for uimm3 field, "
+			    "value must be 0...7"));
+	      ip->insn_opcode |= ENCODE_SPACEMIT_IME_UIMM3 (imm_expr->X_add_number);
+	      imm_expr->X_op = O_absent;
+	      asarg = expr_parse_end;
+	      continue;
+	    case 'h':
+	      my_getExpression (imm_expr, asarg);
+	      check_absolute_expr (ip, imm_expr, FALSE);
+	      if (imm_expr->X_add_number < 0 || imm_expr->X_add_number >= 4)
+		    as_bad (_("bad value for uimm2 field, "
+			    "value must be 0...3"));
+	      ip->insn_opcode |= ENCODE_SPACEMIT_IME_UIMM2 (imm_expr->X_add_number);
+	      imm_expr->X_op = O_absent;
+	      asarg = expr_parse_end;
+	      continue;
+	    case '9':
+	      my_getExpression (imm_expr, asarg);
+	      check_absolute_expr (ip, imm_expr, FALSE);
+	      if (imm_expr->X_add_number < 0 || imm_expr->X_add_number >= 2)
+		    as_bad (_("bad value for uimm2 field, "
+			    "value must be 0..1"));
+	      ip->insn_opcode |= ENCODE_SPACEMIT_IME_UIMM2_SP (imm_expr->X_add_number);
+	      imm_expr->X_op = O_absent;
+	      asarg = expr_parse_end;
+	      continue;
+	    case 'K':
+	      my_getExpression (imm_expr, asarg);
+	      check_absolute_expr (ip, imm_expr, FALSE);
+	      if (imm_expr->X_add_number < 0 || imm_expr->X_add_number >= 4)
+		    as_bad (_("bad value for uimm2 field, "
+			    "value must be 0..3"));
+	      ip->insn_opcode |= ENCODE_SPACEMIT_IME_UIMM2_SP (imm_expr->X_add_number);
+	      imm_expr->X_op = O_absent;
+	      asarg = expr_parse_end;
+	      continue;
+
+
 	    case 'd': /* Destination register.  */
